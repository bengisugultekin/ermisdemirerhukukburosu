{% extends "layouts/base.njk" %}

{% block content %}
<section class="error-404">
  <div class="container">
    <div class="error-404__content">
      <span class="error-404__code">404</span>
      <h1 class="error-404__title">Sayfa Bulunamadı</h1>
      <p class="error-404__text">Aradığınız sayfa taşınmış, silinmiş ya da hiç var olmamış olabilir.</p>
      <div class="error-404__actions">
        <a href="/" class="btn btn--primary">Anasayfaya Dön</a>
        <a href="/#iletisim" class="btn btn--outline">Bize Ulaşın</a>
      </div>
    </div>
  </div>
</section>
{% endblock %}
