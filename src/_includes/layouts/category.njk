{% extends "layouts/base.njk" %}

{% block content %}
  {% include "components/breadcrumb.njk" %}

  <section class="category-page">
    <div class="container">
      <div class="category-page__layout">

        {% include "components/sidebar.njk" %}

        <div class="category-page__articles" id="articles-container">
          {% for article in collections[category] %}
          <article class="category-page__card" data-article-index="{{ loop.index0 }}">
            <p class="category-page__card-meta">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {{ article.data.date | formatDate }}
            </p>
            <h2 class="category-page__card-title">
              <a href="{{ article.url }}">{{ article.data.title }}</a>
            </h2>
            <p class="category-page__card-excerpt">
              {% if article.data.description %}
                {{ article.data.description }}
              {% else %}
                {{ article.templateContent | truncate(200) | safe }}
              {% endif %}
            </p>
            <a href="{{ article.url }}" class="link-arrow">Devamını Oku</a>
          </article>
          {% endfor %}
        </div>

        {% if collections[category].length > 6 %}
        <div class="category-page__load-more">
          <button class="btn btn--outline" id="load-more-btn">Devamını Gör</button>
        </div>
        {% endif %}

      </div>
    </div>
  </section>
{% endblock %}
