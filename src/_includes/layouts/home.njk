{% extends "layouts/base.njk" %}

{% block content %}
  <div class="banner-carousel banner-carousel-1 mb-0">
    <div class="banner-carousel-item" style="background-image:url(/images/slider-main/book.jpg)">
      <div class="slider-content">
        <div class="container h-100">
          <div class="row align-items-center h-100">
            <div class="col-md-12 text-center">
              <h2 class="slide-title" data-animation-in="slideInLeft">
                SÜREKLİ DEĞİŞEN VE GELİŞEN HUKUK DÜNYASINDA</h2>
              <h3 class="slide-sub-title" data-animation-in="slideInRight">30 SENELİK TECRÜBE İLE YANINDAYIZ</h3>
              <p data-animation-in="slideInLeft" data-duration-in="1.2">
                <a href="/services/" class="slider btn btn-primary">HİZMETLERİMİZ</a>
                <a href="/contact/" class="slider btn btn-primary border">BİZE ULAŞIN</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="banner-carousel-item" style="background-image:url(/images/slider-main/grey-marble.jpg)">
      <div class="slider-content text-left">
        <div class="container h-100">
          <div class="row align-items-center h-100">
            <div class="col-md-12">
              <h2 class="slide-title-box" data-animation-in="slideInDown">EN UYGUN EN ETKİLİ</h2>
              <h3 class="slide-title" data-animation-in="fadeIn">UYUŞMAZLIĞINIZIN ÇÖZÜMÜ İÇİN</h3>
              <h3 class="slide-sub-title" data-animation-in="slideInLeft">SEÇİMİNİZ BASİT</h3>
              <p data-animation-in="slideInRight">
                <a href="/services/" class="slider btn btn-primary border">HİZMETLERİMİZ</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="banner-carousel-item" style="background-image:url(/images/slider-main/lawyer.jpg)">
      <div class="slider-content text-right">
        <div class="container h-100">
          <div class="row align-items-center h-100">
            <div class="col-md-12">
              <h2 class="slide-title" data-animation-in="slideInDown">HUKUKİ SORUNLARINIZIN ÇÖZÜMÜ VE ÖNLEMİ İÇİN</h2>
              <h3 class="slide-sub-title" data-animation-in="fadeIn">PROFESYONEL DESTEĞE HAZIRIZ</h3>
              <p class="slider-description lead" data-animation-in="slideInRight">Çok geç olmadan bizimle iletişime geçin</p>
              <div data-animation-in="slideInLeft">
                <a href="/contact/" class="slider btn btn-primary" aria-label="contact-with-us">İLETİŞİM</a>
                <a href="/about/" class="slider btn btn-primary border" aria-label="learn-more-about-us">DAHA FAZLA BİLGİ</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="call-to-action-box no-padding">
    <div class="container">
      <div class="action-style-box">
        <div class="row align-items-center">
          <div class="col-md-8 text-center text-md-left">
            <div class="call-to-action-text">
              <h3 class="action-title">HUKUKİ UYUŞMAZLIK KONUSUNDA BİZİMLE İLETİŞİME GEÇİN</h3>
            </div>
          </div>
          <!-- Col end -->
          <div class="col-md-4 text-center text-md-right mt-3 mt-md-0">
            <div class="call-to-action-btn">
              <a class="btn btn-dark" href="/contact/">BİZE ULAŞIN</a>
            </div>
          </div>
          <!-- col end -->
        </div>
        <!-- row end -->
      </div>
      <!-- Action style box -->
    </div>
    <!-- Container end -->
  </section>
  <!-- Action end -->

  <section id="ts-features" class="ts-features">
    <div class="container">
      <div class="row">
        <div class="col-lg-6">
          <div class="ts-intro">
            <h2 class="into-title">Hakkımızda</h2>
            <h3 class="into-sub-title">ETKİN, HIZLI, GÜVENİLİR HUKUKİ SÜREÇLER</h3>
            <p>Siz değerli müvekkil ve danışanlarımıza, hakkınızın tescil veya müdafaasında yürütülecek hukuki süreci şeffaf olarak anlatıyoruz. Duymak istediklerinizi değil duymanız gerekenleri söyleyerek, etkin ve güvenilir bir vekalet ilişkisi ile hukuki destek sunuyoruz.</p>
          </div>
          <!-- Intro box end -->

          <div class="gap-20"></div>

          <div class="row">
            <div class="col-md-6">
              <div class="ts-service-box">
                <span class="ts-service-icon">
                  <i class="fas fa-trophy"></i>
                </span>
                <div class="ts-service-box-content">
                  <h3 class="service-box-title">ETKİN VE HIZLI SONUÇLAR</h3>
                </div>
              </div>
              <!-- Service 1 end -->
            </div>
            <!-- col end -->

            <div class="col-md-6">
              <div class="ts-service-box">
                <span class="ts-service-icon">
                  <i class="fas fa-sliders-h"></i>
                </span>
                <div class="ts-service-box-content">
                  <h3 class="service-box-title">ŞEFFAF HUKUKİ SÜREÇLER</h3>
                </div>
              </div>
              <!-- Service 2 end -->
            </div>
            <!-- col end -->
          </div>
          <!-- Content row 1 end -->

          <div class="row">
            <div class="col-md-6">
              <div class="ts-service-box">
                <span class="ts-service-icon">
                  <i class="fas fa-thumbs-up"></i>
                </span>
                <div class="ts-service-box-content">
                  <h3 class="service-box-title">GÜVENİLİR VEKALET İLİŞKİSİ</h3>
                </div>
              </div>
              <!-- Service 1 end -->
            </div>
            <!-- col end -->

            <div class="col-md-6">
              <div class="ts-service-box">
                <span class="ts-service-icon">
                  <i class="fas fa-users"></i>
                </span>
                <div class="ts-service-box-content">
                  <h3 class="service-box-title">GÜÇLÜ VE DİNAMİK KADRO</h3>
                </div>
              </div>
              <!-- Service 2 end -->
            </div>
            <!-- col end -->
          </div>
          <!-- Content row 1 end -->
        </div>
        <!-- Col end -->

        <div class="col-lg-6 mt-4 mt-lg-0">
          <h3 class="into-sub-title">DEĞERLERİMİZ</h3>
          <p>Bizden talep ettiğiniz hukuki destek sürecinde, başta Avukatlık Kanunu olmak üzere, tüm yasal sorumluluklarımızı yerine getirerek, etik değerlerimize sahip çıkarak, size şeffaf ve güvenilir hukuki danışma ya da temsil faaliyeti hizmeti için tüm ekip arkadaşlarımızla birlikte yanınızdayız.</p>

          <div class="accordion accordion-group" id="our-values-accordion">
            <div class="card">
              <div class="card-header p-0 bg-transparent" id="headingOne">
                <h2 class="mb-0">
                  <button class="btn btn-block text-left" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                    GÜVENİLİR
                  </button>
                </h2>
              </div>
            </div>
            <div class="card">
              <div class="card-header p-0 bg-transparent" id="headingTwo">
                <h2 class="mb-0">
                  <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    ETİK
                  </button>
                </h2>
              </div>
            </div>
            <div class="card">
              <div class="card-header p-0 bg-transparent" id="headingThree">
                <h2 class="mb-0">
                  <button class="btn btn-block text-left collapsed" type="button" data-toggle="collapse" data-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                    DÜRÜSTLÜK VE DOĞRULUK
                  </button>
                </h2>
              </div>
            </div>
          </div>
          <!--/ Accordion end -->
        </div>
        <!-- Col end -->
      </div>
      <!-- Row end -->
    </div>
    <!-- Container end -->
  </section>
  <!-- Feature are end -->

  <section id="facts" class="facts-area dark-bg">
    <div class="container">
      <div class="facts-wrapper">
        <div class="row">
          <div class="col-md-3 col-sm-6 ts-facts">
            <div class="ts-facts-img">
              <img loading="lazy" src="/images/icon-image/justice.png" alt="facts-img">
            </div>
          </div>
          <!-- Col end -->

          <div class="col-md-3 col-sm-6 ts-facts mt-5 mt-sm-0">
            <div class="ts-facts-img">
              <img loading="lazy" src="/images/icon-image/gavel.png" alt="facts-img">
            </div>
          </div>
          <!-- Col end -->

          <div class="col-md-3 col-sm-6 ts-facts mt-5 mt-md-0">
            <div class="ts-facts-img">
              <img loading="lazy" src="/images/icon-image/court_2.png" alt="facts-img">
            </div>
          </div>
          <!-- Col end -->

          <div class="col-md-3 col-sm-6 ts-facts mt-5 mt-md-0">
            <div class="ts-facts-img">
              <img loading="lazy" src="/images/icon-image/scale.png" alt="facts-img">
            </div>
          </div>
          <!-- Col end -->
        </div>
        <!-- Facts end -->
      </div>
      <!--/ Content row end -->
    </div>
    <!--/ Container end -->
  </section>
  <!-- Facts end -->

  <section id="ts-service-area" class="ts-service-area pb-0">
    <div class="container">
      <div class="row text-center">
        <div class="col-12">
          <h2 class="section-title">UZMANLIKLARIMIZ</h2>
          <h3 class="section-sub-title">HİZMETLERİMİZ</h3>
        </div>
      </div>
      <!--/ Title row end -->

      <div class="row">
        <div class="col-lg-4">
          {% for service in services.categories %}
            {% if loop.index <= 3 %}
            <div class="ts-service-box d-flex">
              <div class="ts-service-box-img">
                <img loading="lazy" src="/{{ service.icon }}" alt="service-icon">
              </div>
              <div class="ts-service-box-info">
                <h3 class="service-box-title"><a href="{{ service.url }}">{{ service.title }}</a></h3>
                <p class="service-box-justify">{{ service.description }}</p>
              </div>
            </div>
            <!-- Service end -->
            {% endif %}
          {% endfor %}
        </div>
        <!-- Col end -->

        <div class="col-lg-4 text-center">
          <img loading="lazy" class="img-fluid" src="/images/services/lawyer.png" alt="service-avater-image">
        </div>
        <!-- Col end -->

        <div class="col-lg-4 mt-5 mt-lg-0 mb-4 mb-lg-0">
          {% for service in services.categories %}
            {% if loop.index > 3 %}
            <div class="ts-service-box d-flex">
              <div class="ts-service-box-img">
                <img loading="lazy" src="/{{ service.icon }}" alt="service-icon">
              </div>
              <div class="ts-service-box-info">
                <h3 class="service-box-title"><a href="{{ service.url }}">{{ service.title }}</a></h3>
                <p class="service-box-justify">{{ service.description }}</p>
              </div>
            </div>
            <!-- Service end -->
            {% endif %}
          {% endfor %}
        </div>
        <!-- Col end -->
      </div>
      <!-- Content row end -->
    </div>
    <!--/ Container end -->
  </section>
  <!-- Service end -->

  <section class="subscribe no-padding">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <div class="subscribe-call-to-acton">
            <h3>BİZE ULAŞIN</h3>
            <h4>{{ site.contact.phone }} - {{ site.contact.office }}</h4>
          </div>
        </div>
        <!-- Col end -->

        <div class="col-md-6">
          <div class="ts-newsletter row align-items-center">
            <div class="col-md-12 newsletter-introtext">
              <h4 class="text-white mb-0">EPOSTA ADRESİMİZ</h4>
              <p class="text-white">{{ site.contact.email }}</p>
            </div>
          </div>
          <!-- Newsletter end -->
        </div>
        <!-- Col end -->
      </div>
      <!-- Content row end -->
    </div>
    <!--/ Container end -->
  </section>
  <!--/ subscribe end -->
{% endblock %}
