<div class="header-sentinel" id="headerSentinel"></div>

<header class="header" id="header">
  <div class="container">
    <div class="header__inner">

      <a href="/" class="header__logo" aria-label="Anasayfa">
        <img src="/images/logo.svg" alt="Ermiş Hukuk Bürosu" width="60" height="45">
        <span class="header__logo-text">ERMİŞ HUKUK BÜROSU</span>
      </a>

      <nav class="header__nav" aria-label="Ana menü">
        <a href="/#hizmetler" class="header__nav-link" data-section="hizmetler">Hizmetler</a>
        <a href="/#makaleler" class="header__nav-link" data-section="makaleler">Makaleler</a>
        <a href="/#hakkimizda" class="header__nav-link" data-section="hakkimizda">Hakkımızda</a>
        <a href="/#avukatlar" class="header__nav-link" data-section="avukatlar">Avukatlar</a>
        <a href="/#iletisim" class="header__nav-link" data-section="iletisim">İletişim</a>
      </nav>


      <button class="header__toggle" id="navToggle" aria-label="Menüyü aç/kapat" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </div>
</header>

<div class="mobile-nav" id="mobileNav" aria-label="Mobil menü">
  <a href="/#hizmetler" class="mobile-nav__link">Hizmetler</a>
  <a href="/#makaleler" class="mobile-nav__link">Makaleler</a>
  <a href="/#hakkimizda" class="mobile-nav__link">Hakkımızda</a>
  <a href="/#avukatlar" class="mobile-nav__link">Avukatlar</a>
  <a href="/#iletisim" class="mobile-nav__link">İletişim</a>
  <div class="mobile-nav__contact">
    <a href="tel:{{ site.contact.phone | replace('(', '') | replace(')', '') | replace(' ', '') }}">{{ site.contact.phone }}</a>
    <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
  </div>
</div>
