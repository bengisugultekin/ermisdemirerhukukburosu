{% if breadcrumbs %}
<div class="breadcrumb-section">
  <div class="container">
    <h1 class="breadcrumb-section__title">{{ title }}</h1>
    <nav aria-label="Sayfa konumu">
      <ol class="breadcrumb-section__list">
        {% for crumb in breadcrumbs %}
          {% if loop.last %}
            <li aria-current="page">{{ crumb.title }}</li>
          {% else %}
            <li><a href="{{ crumb.url }}">{{ crumb.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ol>
    </nav>
  </div>
</div>
{% endif %}
