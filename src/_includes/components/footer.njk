<footer class="footer" id="footer">
  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <div class="footer__about">
          <h3 class="footer__title">Hakkımızda</h3>
          <picture>
            <source srcset="/images/footer-logo.webp" type="image/webp">
            <img loading="lazy" class="footer__logo" src="/images/footer-logo.png" alt="Ermiş Hukuk Bürosu" width="200" height="40">
          </picture>
          <p>Ermiş Hukuk Bürosu olarak; tarafı olduğunuz her hukuki ilişkide sizleri en iyi şekilde temsil ediyor ve hukuki danışmanlık veriyoruz.</p>
          <div class="footer__social">
            <a href="{{ site.social.whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            </a>
            <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            {% for linkedin in site.social.linkedin %}
            <a href="{{ linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            {% endfor %}
          </div>
        </div>

        <div>
          <h3 class="footer__title">Çalışma Saatleri</h3>
          <div class="footer__hours">
            <div class="hours-row">
              <span>Pazartesi - Cuma</span>
              <span>{{ site.workingHours.weekdays }}</span>
            </div>
            <div class="hours-row">
              <span>Cumartesi</span>
              <span>{{ site.workingHours.saturday }}</span>
            </div>
            <div class="hours-row">
              <span>Pazar</span>
              <span>Kapalı</span>
            </div>
          </div>
        </div>

        <div>
          <h3 class="footer__title">Hizmetlerimiz</h3>
          <ul class="footer__links">
            {% for service in services.categories %}
            <li><a href="{{ service.url }}">{{ service.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

      </div>
    </div>
  </div>

  <div class="container">
    <div class="footer__bottom">
      <p class="footer__copyright">&copy; <span id="currentYear"></span> {{ site.title }}. Tüm hakları saklıdır.</p>
      <div class="footer__bottom-links">
        <a href="/#hakkimizda">Hakkımızda</a>
        <a href="/#hizmetler">Hizmetlerimiz</a>
        <a href="/#iletisim">İletişim</a>
      </div>
    </div>
  </div>
</footer>
